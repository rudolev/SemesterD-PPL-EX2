{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug q3.ts with tsx",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "watch" 
      ],
      "args": [
        "${workspaceFolder}/test/debug.ts"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}